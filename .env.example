# GCP / BigQuery
GCP_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=credentials/gcp-service-account.json

# BigQuery extraction window (ISO-8601). Default = full GA sample year.
BQ_DATASET=bigquery-public-data.google_analytics_sample
BQ_START_DATE=2016-08-01
BQ_END_DATE=2017-08-01

# Connection resilience (exponential backoff retries).
BQ_MAX_RETRIES=3

# Outputs & runtime
DATA_DIR=data
LOG_LEVEL=INFO
DATABASE_URL=postgresql://user:pass@localhost:5433/marketing_db
