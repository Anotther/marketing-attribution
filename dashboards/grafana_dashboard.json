    {
      "id": 6,
      "type": "barchart",
      "title": "Revenue by Attribution Model",
      "description": "Compares how much revenue is credited to each channel according to the different attribution models. (Requirement: RF5.1)",
      "transparent": true,
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  channel_name,\n  first_click_revenue  AS \"First-Click\",\n  last_click_revenue   AS \"Last-Click\",\n  linear_revenue       AS \"Linear\",\n  markov_revenue       AS \"Markov\",\n  shapley_revenue      AS \"Shapley\"\nFROM resultados_atribuicao\nORDER BY channel_name"
        }
      ],
