    {
      "id": 9,
      "type": "table",
      "title": "Attribution Results (Detail)",
      "description": "Tabular breakdown of credit and revenue assigned to each channel by model. Ranked by Shapley Value.",
      "transparent": true,
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  channel_name,\n  ROUND(first_click_credit, 3)  AS first_click,\n  ROUND(last_click_credit, 3)   AS last_click,\n  ROUND(linear_credit, 3)       AS linear,\n  ROUND(markov_credit, 3)       AS markov,\n  ROUND(shapley_credit, 3)      AS shapley,\n  ROUND(first_click_revenue, 2) AS first_click_rev,\n  ROUND(markov_revenue, 2)      AS markov_rev,\n  ROUND(shapley_revenue, 2)     AS shapley_rev\nFROM resultados_atribuicao\nORDER BY shapley_credit DESC"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Shapley",
            "desc": true
          }
        ],
        "cellHeight": "sm"
